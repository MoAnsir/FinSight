{
  "name": "@finsight/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy --schema=prisma/schema.prisma",
    "db:studio": "prisma studio --env-file=.env",
    "db:seed": "tsx --env-file=.env prisma/seed.ts",
    "db:seed:transactions": "tsx --env-file=.env prisma/seed-transactions.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.3",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.0.2",
    "@fastify/helmet": "^13.0.1",
    "@fastify/jwt": "^9.0.3",
    "@fastify/multipart": "^9.0.3",
    "@fastify/rate-limit": "^10.2.2",
    "@fastify/swagger": "^9.4.0",
    "@fastify/swagger-ui": "^5.2.2",
    "@fastify/websocket": "^11.2.0",
    "@finsight/config": "workspace:*",
    "@finsight/types": "workspace:*",
    "@prisma/client": "^6.2.1",
    "bcryptjs": "^2.4.3",
    "csv-parse": "^5.6.0",
    "fastify": "^5.2.1",
    "fastify-metrics": "^13.2.1",
    "zod": "^3.24.1"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@finsight/eslint-config": "workspace:*",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.6",
    "prisma": "^6.2.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
